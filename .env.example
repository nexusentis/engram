# =============================================================================
# Engram Environment Variables
# =============================================================================
# Copy to .env and set your API key:  cp .env.example .env

# Required
OPENAI_API_KEY=sk-your-key-here

# =============================================================================
# Qdrant (defaults work with ./scripts/setup-qdrant.sh or docker compose)
# =============================================================================
# ENGRAM_QDRANT_URL=http://localhost:6334

# =============================================================================
# Server
# =============================================================================
# ENGRAM_HOST=0.0.0.0
# ENGRAM_PORT=8080

# =============================================================================
# Extraction
# =============================================================================
# ENGRAM_EXTRACTION_MODE=local-accurate  # "local-fast", "local-accurate", "api-sota"
# ENGRAM_CONFIDENCE_THRESHOLD=0.5
# ANTHROPIC_API_KEY=sk-ant-...           # Only needed for api-sota mode

# =============================================================================
# Retrieval
# =============================================================================
# ENGRAM_RERANKING=true
# ENGRAM_TOP_K=20
# ENGRAM_RRF_K=60

# =============================================================================
# Reranker (ONNX cross-encoder)
# =============================================================================
# RERANKER_ENABLED=true
# RERANKER_MODEL_PATH=models/ms-marco-MiniLM-L-6-v2
# RERANKER_DEPTH=50
# RERANKER_BATCH_SIZE=16

# =============================================================================
# Benchmark — LongMemEval-S
# =============================================================================
# FULL_BENCHMARK=1                                     # Run all 500 questions
# QUESTION_IDS=@data/longmemeval/fast_60.txt           # Or gate_231.txt, fixcheck_81.txt
# INGESTION=full                                        # full | skip | incremental
# INGESTION_ONLY=1                                      # Ingest without answering
# INGESTION_MODEL=gpt-4o-mini
# INGESTION_CONCURRENCY=100
# ANSWER_MODEL=gpt-4o
# ANSWER_CONCURRENCY=7
# ANSWER_TEMP=0.0
